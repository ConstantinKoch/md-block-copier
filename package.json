{
  "name": "md-block-copier",
  "displayName": "MD Block Copier",
  "description": "Copy the inner content of fenced ```md blocks in VS Code.",
  "version": "0.1.0",
  "publisher": "constantinkoch",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md.copyCurrent",
        "title": "MD Block Copier: Copy Current MD Block"
      },
      {
        "command": "md.copyNext",
        "title": "MD Block Copier: Copy Next MD Block"
      }
    ],
    "keybindings": [
      {
        "command": "md.copyCurrent",
        "key": "cmd+alt+m",
        "mac": "cmd+alt+m",
        "when": "editorTextFocus"
      },
      {
        "command": "md.copyNext",
        "key": "cmd+alt+n",
        "mac": "cmd+alt+n",
        "when": "editorTextFocus"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ConstantinKoch/md-block-copier.git"
  },
  "homepage": "https://github.com/ConstantinKoch/md-block-copier",
  "bugs": {
    "url": "https://github.com/ConstantinKoch/md-block-copier/issues"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "typescript": "^5.9.3"
  }
}
